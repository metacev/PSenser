gen/
generated/

# Debug & Release folders
debug/
release/

# Proguard
proguard/

# Coverage reports
coverage/
*.ec
*.lcov

# APK Analyzer
.apk-analyzer/

# Android device logs
adb.log

# Temporary files
*.tmp
*.temp

# IDE files
.idea/
*.iml
*.iws

# Environment
.env
.env.local
.env.*

# OS generated files
.DS_Store
Thumbs.db
```